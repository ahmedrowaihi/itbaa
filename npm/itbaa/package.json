{
  "name": "@ahmedrowaihi/itbaa",
  "version": "0.0.0-dev",
  "description": "Convert HTML to PDF, PNG, or JPEG offline — vector PDFs with selectable text, full CSS, web fonts, and Arabic/RTL. Powered by Ladybird.",
  "keywords": [
    "html-to-pdf",
    "pdf",
    "html",
    "png",
    "jpeg",
    "screenshot",
    "render",
    "ladybird",
    "arabic",
    "rtl"
  ],
  "homepage": "https://github.com/ahmedrowaihi/itbaa",
  "bugs": "https://github.com/ahmedrowaihi/itbaa/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/itbaa.git",
    "directory": "npm/itbaa"
  },
  "license": "Apache-2.0",
  "author": "sudorw <ahmedrowaihi@sudorw.com>",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "itbaa": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsdown": "^0.22.2",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "@ahmedrowaihi/itbaa-linux-x64": "0.0.0-dev",
    "@ahmedrowaihi/itbaa-linux-arm64": "0.0.0-dev",
    "@ahmedrowaihi/itbaa-darwin-arm64": "0.0.0-dev"
  }
}
