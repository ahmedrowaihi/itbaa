new file mode 100644
index 00000000000..983c8bdcbc9
--- /dev/null
+++ b/Utilities/Itbaa/lib/PageRange.cpp
@@ -0,0 +1,65 @@
+/*
+ * Itbaa (اطبع) - HTML to PDF Conversion Library
+ * Copyright (c) 2025, sudorw <ahmedrowaihi@sudorw.com>
+ * SPDX-License-Identifier: BSD-2-Clause
+ */
+
+#include "PageRange.h"
+
+#include <AK/HashTable.h>
+#include <AK/QuickSort.h>
+
+namespace Itbaa {
+
+static ErrorOr<u32> parse_bound(StringView token, u32 fallback)
+{
+    token = token.trim_whitespace();
+    if (token.is_empty())
+        return fallback;
+    auto value = token.to_number<u32>();
+    if (!value.has_value())
+        return Error::from_string_literal("invalid page number in range");
+    return value.value();
+}
+
+ErrorOr<Vector<u32>> parse_page_range(StringView spec, u32 total_pages)
+{
+    Vector<u32> pages;
+    if (total_pages == 0)
+        return pages;
+
+    if (spec.trim_whitespace().is_empty()) {
+        for (u32 page = 1; page <= total_pages; ++page)
+            pages.append(page);
+        return pages;
+    }
+
+    HashTable<u32> seen;
+    for (auto segment : spec.split_view(',')) {
+        segment = segment.trim_whitespace();
+        if (segment.is_empty())
+            continue;
+
+        auto dash = segment.find('-');
+        u32 first;
+        u32 last;
+        if (dash.has_value()) {
+            first = TRY(parse_bound(segment.substring_view(0, dash.value()), 1));
+            last = TRY(parse_bound(segment.substring_view(dash.value() + 1), total_pages));
+        } else {
+            first = last = TRY(parse_bound(segment, 0));
+        }
+
+        first = max(first, 1u);
+        last = min(last, total_pages);
+        for (u32 page = first; page <= last; ++page) {
+            if (seen.set(page) == HashSetResult::InsertedNewEntry)
+                pages.append(page);
+        }
+    }
+
+    quick_sort(pages);
+    return pages;
+}
+
+}
