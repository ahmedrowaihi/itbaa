@@ -0,0 +1,49 @@
+/*
+ * Itbaa (اطبع) - HTML to PDF Conversion Library
+ * Copyright (c) 2025, sudorw <ahmedrowaihi@sudorw.com>
+ * SPDX-License-Identifier: BSD-2-Clause
+ */
+
+#include "InProcessImageCodecPlugin.h"
+
+#include <LibGfx/ImageFormats/ImageDecoder.h>
+
+namespace Itbaa {
+
+NonnullRefPtr<Core::Promise<Web::Platform::DecodedImage>> InProcessImageCodecPlugin::decode_image(
+    ReadonlyBytes bytes,
+    Function<ErrorOr<void>(Web::Platform::DecodedImage&)> on_resolved,
+    Function<void(Error&)> on_rejected)
+{
+    auto promise = Core::Promise<Web::Platform::DecodedImage>::construct();
+    if (on_resolved)
+        promise->on_resolution = move(on_resolved);
+    if (on_rejected)
+        promise->on_rejection = move(on_rejected);
+
+    auto decoder = Gfx::ImageDecoder::try_create_for_raw_bytes(bytes);
+    if (decoder.is_error() || !decoder.value()) {
+        promise->reject(Error::from_string_literal("Failed to create image decoder"));
+        return promise;
+    }
+    auto image_decoder = decoder.release_value();
+
+    Web::Platform::DecodedImage decoded;
+    decoded.is_animated = image_decoder->is_animated();
+    decoded.loop_count = image_decoder->loop_count();
+    decoded.frame_count = image_decoder->frame_count();
+    for (size_t i = 0; i < image_decoder->frame_count(); ++i) {
+        auto frame = image_decoder->frame(i);
+        if (frame.is_error()) {
+            promise->reject(Error::from_string_literal("Failed to decode image frame"));
+            return promise;
+        }
+        decoded.frames.empend(frame.value().image, static_cast<size_t>(frame.value().duration));
+        decoded.all_durations.append(frame.value().duration);
+    }
+
+    promise->resolve(move(decoded));
+    return promise;
+}
+
+}
