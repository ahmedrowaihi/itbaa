+
+// Parses a 1-based page-range spec ("3", "2-5", "3-", "-4", "1,3,5-7") clamped to [1, total_pages].
+// An empty spec selects every page. Returns the selected page numbers, sorted, unique, ascending.
+ErrorOr<Vector<u32>> parse_page_range(StringView spec, u32 total_pages);
+
