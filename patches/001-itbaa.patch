+
+#include "RequestClientFactory.h"
+
+#include <LibIPC/Transport.h>
+
+namespace Itbaa {
+
+ErrorOr<NonnullRefPtr<Requests::RequestClient>> create_request_client()
+{
+    auto paired = TRY(IPC::Transport::create_paired());
+    return try_make_ref_counted<Requests::RequestClient>(move(paired.local));
+}
+
+}
