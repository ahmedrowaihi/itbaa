+// PDF metadata
+struct PDFMetadata {
+    StringView title { "Itbaa PDF"sv };
+    StringView author {};
+    StringView subject {};
+    StringView creator { "Itbaa (اطبع)"sv };
+};
+
+class PDFWriter {
+public:
+    PDFWriter() = default;
+    ~PDFWriter() = default;
+
+    // Set PDF metadata
+    void set_metadata(PDFMetadata const& metadata) { m_metadata = metadata; }
+
+    // Generate PDF from rendered pages. When rasterize is set, each page is drawn as a
+    // raster image (at raster_scale resolution) instead of vector content.
+    ErrorOr<ByteBuffer> generate(Vector<RenderedPage> const& pages, bool rasterize = false, float raster_scale = 2.0f);
+
+    // Generate PDF and write to file
+    ErrorOr<void> generate_to_file(Vector<RenderedPage> const& pages, StringView path, bool rasterize = false, float raster_scale = 2.0f);
+
+private:
+    PDFMetadata m_metadata;
+};
+
+} // namespace Itbaa
