+/*
+ * Itbaa (اطبع) - HTML to PDF CLI
+ * Copyright (c) 2025, sudorw <ahmedrowaihi@sudorw.com>
+ * SPDX-License-Identifier: BSD-2-Clause
+ */
+
+#include "Itbaa.h"
+#include <AK/ByteString.h>
+#include <AK/LexicalPath.h>
+#include <AK/QuickSort.h>
+#include <AK/Vector.h>
+#include <LibCore/DirIterator.h>
+#include <LibCore/System.h>
+#include <LibFileSystem/FileSystem.h>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <fcntl.h>
+#include <unistd.h>
+
+namespace {
+
+enum class Format {
+    Human,
+    Json,
+};
+
+enum class Verbosity {
+    Quiet,
+    Normal,
+    Verbose,
+};
+
+struct Options {
+    Format format { Format::Human };
+    Verbosity verbosity { Verbosity::Normal };
+    ItbaaOptions render { itbaa_default_options() };
+    unsigned timeout { 0 };
+    char const* out_dir { nullptr };
+    char const* to { nullptr }; // Derived-output extension for batch: pdf | png | jpg
+};
+
+// True when a name ends in an extension we render to (selects explicit-pair vs derived outputs).
+bool is_output_name(StringView name)
+{
+    return name.ends_with(".pdf"sv, CaseSensitivity::CaseInsensitive)
+        || name.ends_with(".png"sv, CaseSensitivity::CaseInsensitive)
+        || name.ends_with(".jpg"sv, CaseSensitivity::CaseInsensitive)
+        || name.ends_with(".jpeg"sv, CaseSensitivity::CaseInsensitive);
+}
+
+bool is_image_name(StringView name)
+{
+    return name.ends_with(".png"sv, CaseSensitivity::CaseInsensitive)
+        || name.ends_with(".jpg"sv, CaseSensitivity::CaseInsensitive)
+        || name.ends_with(".jpeg"sv, CaseSensitivity::CaseInsensitive);
+}
+
+// Redirects the engine's stderr diagnostics to /dev/null for its lifetime unless --verbose.
+class StderrSilencer {
+public:
+    explicit StderrSilencer(bool silence)
+    {
+        if (!silence)
+            return;
+        int devnull = open("/dev/null", O_WRONLY);
+        if (devnull < 0)
+            return;
+        m_saved = dup(STDERR_FILENO);
+        if (m_saved >= 0)
+            dup2(devnull, STDERR_FILENO);
+        close(devnull);
+    }
+    ~StderrSilencer()
+    {
+        if (m_saved >= 0) {
+            dup2(m_saved, STDERR_FILENO);
+            close(m_saved);
+        }
+    }
+    StderrSilencer(StderrSilencer const&) = delete;
+    StderrSilencer& operator=(StderrSilencer const&) = delete;
+
+private:
+    int m_saved { -1 };
+};
+
+void json_print_string(char const* s)
+{
+    putchar('"');
+    for (; s && *s; ++s) {
+        switch (*s) {
+        case '"':
+            fputs("\\\"", stdout);
+            break;
+        case '\\':
+            fputs("\\\\", stdout);
+            break;
+        case '\n':
+            fputs("\\n", stdout);
+            break;
+        case '\r':
+            fputs("\\r", stdout);
+            break;
+        case '\t':
+            fputs("\\t", stdout);
+            break;
+        default:
+            if ((unsigned char)*s < 0x20)
+                printf("\\u%04x", (unsigned char)*s);
+            else
+                putchar(*s);
+        }
+    }
+    putchar('"');
+}
+
+// Reports an error as JSON on stdout or a plain line on stderr; always returns 1.
+int report_error(Options const& o, ItbaaError err, char const* context)
+{
+    char const* message = itbaa_error_string(err);
+    if (o.format == Format::Json) {
+        printf("{\"ok\":false,\"code\":%d,\"message\":", (int)err);
+        if (context) {
+            // Combine "context: message" into one JSON string.
+            char buffer[1024];
+            snprintf(buffer, sizeof(buffer), "%s: %s", context, message);
+            json_print_string(buffer);
+        } else {
+            json_print_string(message);
+        }
+        fputs("}\n", stdout);
+    } else if (context) {
+        fprintf(stderr, "error: %s: %s\n", context, message);
+    } else {
+        fprintf(stderr, "error: %s\n", message);
+    }
+    return 1;
+}
+
+void print_usage()
+{
+    printf("itbaa %s - HTML to PDF, powered by Ladybird\n\n", itbaa_version());
+    printf("Usage:\n");
+    printf("  itbaa render <input.html> [output.pdf|.png|.jpg] [options]\n");
+    printf("  itbaa render <input.html>... [--out-dir DIR] [--to FMT] [options]\n");
+    printf("  itbaa render <folder> [--out-dir DIR] [--to FMT] [options]\n");
+    printf("  itbaa info   <input.html> [options]\n");
+    printf("  itbaa version | help\n\n");
+    printf("Render takes one or many inputs (files or a folder). With one input and an\n");
+    printf("explicit output, that name is used; otherwise output names are derived (<name>.<fmt>).\n");
+    printf("The output extension selects the format: .pdf, .png or .jpg.\n\n");
+    printf("Options:\n");
+    printf("  --pages <RANGE>    Pages to render: 3, 2-5, 3-, -4, 1,3,5-7 (default: all)\n");
+    printf("  --single-page      One tall page, no page breaks (avoids cut content)\n");
+    printf("  --raster           Embed pages as images in the PDF (no selectable text)\n");
+    printf("  --scale <N>        Resolution multiplier for image/raster output (default: 2)\n");
+    printf("  --to <FMT>         Derived-output format for batch: pdf | png | jpg\n");
+    printf("  --out-dir <DIR>    Write derived outputs into DIR (batch)\n");
+    printf("  --size <PRESET>    a4 | letter | legal | a3 (default: a4)\n");
+    printf("  --width <PX>       Custom page width (overrides --size)\n");
+    printf("  --height <PX>      Custom page height (overrides --size)\n");
+    printf("  --no-full-page     Don't capture full scrollable content\n");
+    printf("  --timeout <SEC>    Max seconds to wait for resources (default: 10)\n");
+    printf("  --format <FMT>     Output format: human | json (default: human)\n");
+    printf("  -q, --quiet        Suppress diagnostics and success lines\n");
+    printf("  -v, --verbose      Show engine diagnostics\n");
+    printf("  -h, --help         Show this help\n");
+}
+
+// Parses one shared option at argv[i], advancing i past any value.
+// Returns 1 if consumed, 0 if not a known flag, -1 on a malformed flag.
+int parse_option(int argc, char** argv, int& i, Options& o)
+{
+    char const* arg = argv[i];
+
+    auto value = [&](char const** out) {
+        if (i + 1 >= argc)
+            return false;
+        *out = argv[++i];
+        return true;
+    };
+
+    if (strcmp(arg, "--format") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        if (strcmp(v, "json") == 0)
+            o.format = Format::Json;
+        else if (strcmp(v, "human") == 0)
+            o.format = Format::Human;
+        else
+            return -1;
+        return 1;
+    }
+    if (strcmp(arg, "-q") == 0 || strcmp(arg, "--quiet") == 0) {
+        o.verbosity = Verbosity::Quiet;
+        return 1;
+    }
+    if (strcmp(arg, "-v") == 0 || strcmp(arg, "--verbose") == 0) {
+        o.verbosity = Verbosity::Verbose;
+        return 1;
+    }
+    if (strcmp(arg, "--pages") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        o.render.pages = v;
+        return 1;
+    }
+    if (strcmp(arg, "--size") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        if (strcmp(v, "a4") == 0)
+            o.render.page_size = ITBAA_PAGE_A4;
+        else if (strcmp(v, "letter") == 0)
+            o.render.page_size = ITBAA_PAGE_LETTER;
+        else if (strcmp(v, "legal") == 0)
+            o.render.page_size = ITBAA_PAGE_LEGAL;
+        else if (strcmp(v, "a3") == 0)
+            o.render.page_size = ITBAA_PAGE_A3;
+        else
+            return -1;
+        return 1;
+    }
+    if (strcmp(arg, "--width") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        o.render.width = (uint32_t)atoi(v);
+        o.render.page_size = ITBAA_PAGE_CUSTOM;
+        return 1;
+    }
+    if (strcmp(arg, "--height") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        o.render.height = (uint32_t)atoi(v);
+        o.render.page_size = ITBAA_PAGE_CUSTOM;
+        return 1;
+    }
+    if (strcmp(arg, "--no-full-page") == 0) {
+        o.render.full_page = 0;
+        return 1;
+    }
+    if (strcmp(arg, "--single-page") == 0) {
+        o.render.single_page = 1;
+        return 1;
+    }
+    if (strcmp(arg, "--raster") == 0) {
+        o.render.rasterize = 1;
+        return 1;
+    }
+    if (strcmp(arg, "--scale") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        o.render.scale = (float)atof(v);
+        return 1;
+    }
+    if (strcmp(arg, "--to") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        if (strcmp(v, "pdf") != 0 && strcmp(v, "png") != 0 && strcmp(v, "jpg") != 0 && strcmp(v, "jpeg") != 0)
+            return -1;
+        o.to = v;
+        return 1;
+    }
+    if (strcmp(arg, "--timeout") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        o.timeout = (unsigned)atoi(v);
+        return 1;
+    }
+    if (strcmp(arg, "--out-dir") == 0) {
+        char const* v;
+        if (!value(&v))
+            return -1;
+        o.out_dir = v;
+        return 1;
+    }
+    return 0;
+}
+
+// Collects shared options and all positional arguments.
+int parse_args(int argc, char** argv, Options& o, Vector<char const*>& positionals)
+{
+    for (int i = 1; i < argc; i++) {
+        int consumed = parse_option(argc, argv, i, o);
+        if (consumed == -1) {
+            fprintf(stderr, "error: invalid value for option '%s'\n", argv[i]);
+            return 1;
+        }
+        if (consumed == 1)
+            continue;
+        if (argv[i][0] == '-') {
+            fprintf(stderr, "error: unknown option '%s'\n", argv[i]);
+            return 1;
+        }
+        positionals.append(argv[i]);
+    }
+    return 0;
+}
+
+struct Job {
+    ByteString input;
+    ByteString output;
+};
+
+ByteString derive_output(StringView input, char const* out_dir, char const* ext)
+{
+    LexicalPath path { input };
+    auto name = ByteString::formatted("{}.{}", path.title(), ext ? ext : "pdf");
+    return LexicalPath::join(out_dir ? StringView { out_dir, strlen(out_dir) } : path.dirname(), name).string();
+}
+
+// Expands a positional into input files: an *.html/*.htm folder listing, or the file itself.
+Vector<ByteString> expand_input(StringView path)
+{
+    Vector<ByteString> files;
+    if (FileSystem::is_directory(path)) {
+        Core::DirIterator it { path, Core::DirIterator::SkipParentAndBaseDir };
+        while (it.has_next()) {
+            auto name = it.next_path();
+            if (name.ends_with(".html"sv) || name.ends_with(".htm"sv))
+                files.append(LexicalPath::join(path, name).string());
+        }
+        quick_sort(files);
+    } else {
+        files.append(path);
+    }
+    return files;
+}
+
+// Builds the input->output jobs from positionals:
+//  --out-dir set      -> every input, outputs derived into out_dir
+//  <in> <out.pdf>     -> a single explicit pair
+//  otherwise          -> every input, output derived next to it
+Vector<Job> resolve_jobs(Vector<char const*> const& positionals, char const* out_dir, char const* ext)
+{
+    Vector<Job> jobs;
+    bool explicit_pair = !out_dir && positionals.size() == 2 && is_output_name({ positionals[1], strlen(positionals[1]) });
+    if (explicit_pair) {
+        jobs.append({ positionals[0], positionals[1] });
+        return jobs;
+    }
+    for (auto* positional : positionals) {
+        for (auto& file : expand_input({ positional, strlen(positional) }))
+            jobs.append({ file, derive_output(file, out_dir, ext) });
+    }
+    return jobs;
+}
+
+void emit_job_result(Options const& o, Job const& job, ItbaaError err, ItbaaDocumentInfo const& info)
+{
+    if (o.format == Format::Json) {
+        if (err == ITBAA_OK) {
+            fputs("{\"ok\":true,\"input\":", stdout);
+            json_print_string(job.input.characters());
+            fputs(",\"output\":", stdout);
+            json_print_string(job.output.characters());
+            printf(",\"pages\":%u,\"page_width\":%u,\"page_height\":%u}\n", info.page_count, info.page_width, info.page_height);
+        } else {
+            fputs("{\"ok\":false,\"input\":", stdout);
+            json_print_string(job.input.characters());
+            printf(",\"code\":%d,\"message\":", (int)err);
+            json_print_string(itbaa_error_string(err));
+            fputs("}\n", stdout);
+        }
+    } else if (err != ITBAA_OK) {
+        fprintf(stderr, "error: %s: %s\n", job.input.characters(), itbaa_error_string(err));
+    } else if (o.verbosity != Verbosity::Quiet) {
+        printf("rendered %u page(s) -> %s\n", info.page_count, job.output.characters());
+    }
+}
+
+int cmd_render(int argc, char** argv)
+{
+    Options o;
+    Vector<char const*> positionals;
+    if (parse_args(argc, argv, o, positionals) != 0)
+        return 1;
+    if (positionals.is_empty()) {
+        fprintf(stderr, "error: usage: itbaa render <input.html> [output.pdf] [--out-dir DIR]\n");
+        return 1;
+    }
+
+    auto jobs = resolve_jobs(positionals, o.out_dir, o.to);
+    if (jobs.is_empty()) {
+        fprintf(stderr, "error: no input files found\n");
+        return 1;
+    }
+    if (o.out_dir) {
+        StringView dir { o.out_dir, strlen(o.out_dir) };
+        if (!FileSystem::is_directory(dir) && Core::System::mkdir(dir, 0755).is_error()) {
+            fprintf(stderr, "error: cannot create output directory '%s'\n", o.out_dir);
+            return 1;
+        }
+    }
+
+    if (ItbaaError err = itbaa_init(); err != ITBAA_OK)
+        return report_error(o, err, "init");
+    if (o.timeout > 0)
+        itbaa_set_timeout(o.timeout);
+
+    int failures = 0;
+    for (auto& job : jobs) {
+        ItbaaContext* ctx = itbaa_context_create();
+        if (!ctx) {
+            emit_job_result(o, job, ITBAA_ERROR_MEMORY_ALLOCATION, {});
+            ++failures;
+            continue;
+        }
+        bool image_output = is_image_name({ job.output.characters(), job.output.length() });
+        ItbaaOptions render = o.render;
+        if (image_output)
+            render.single_page = 1;
+
+        ItbaaError err;
+        ItbaaDocumentInfo info {};
+        {
+            StderrSilencer silence(o.verbosity != Verbosity::Verbose);
+            err = itbaa_load_html_file(ctx, job.input.characters());
+            if (err == ITBAA_OK)
+                err = image_output
+                    ? itbaa_render_to_image_file(ctx, &render, job.output.characters())
+                    : itbaa_convert_to_file(ctx, &render, job.output.characters());
+            if (err == ITBAA_OK)
+                itbaa_get_info(ctx, &render, &info);
+        }
+        itbaa_context_destroy(ctx);
+        emit_job_result(o, job, err, info);
+        if (err != ITBAA_OK)
+            ++failures;
+    }
+    itbaa_shutdown();
+    return failures == 0 ? 0 : 1;
+}
+
+int cmd_info(int argc, char** argv)
+{
+    Options o;
+    Vector<char const*> positionals;
+    if (parse_args(argc, argv, o, positionals) != 0)
+        return 1;
+    if (positionals.size() != 1) {
+        fprintf(stderr, "error: usage: itbaa info <input.html>\n");
+        return 1;
+    }
+    char const* input = positionals[0];
+
+    if (ItbaaError err = itbaa_init(); err != ITBAA_OK)
+        return report_error(o, err, "init");
+    if (o.timeout > 0)
+        itbaa_set_timeout(o.timeout);
+
+    ItbaaContext* ctx = itbaa_context_create();
+    if (!ctx) {
+        itbaa_shutdown();
+        return report_error(o, ITBAA_ERROR_MEMORY_ALLOCATION, "context");
+    }
+
+    ItbaaError err;
+    ItbaaDocumentInfo info {};
+    {
+        StderrSilencer silence(o.verbosity != Verbosity::Verbose);
+        err = itbaa_load_html_file(ctx, input);
+        if (err == ITBAA_OK)
+            err = itbaa_get_info(ctx, &o.render, &info);
+    }
+    itbaa_context_destroy(ctx);
+    itbaa_shutdown();
+
+    if (err != ITBAA_OK)
+        return report_error(o, err, input);
+
+    if (o.format == Format::Json) {
+        printf("{\"ok\":true,\"pages\":%u,\"content_width\":%u,\"content_height\":%u,\"page_width\":%u,\"page_height\":%u}\n",
+            info.page_count, info.content_width, info.content_height, info.page_width, info.page_height);
+    } else {
+        printf("pages:   %u\n", info.page_count);
+        printf("content: %ux%u\n", info.content_width, info.content_height);
+        printf("page:    %ux%u\n", info.page_width, info.page_height);
+    }
+    return 0;
+}
+
+} // namespace
+
+int main(int argc, char* argv[])
+{
+    if (argc < 2) {
+        print_usage();
+        return 1;
+    }
+
+    char const* command = argv[1];
+    if (strcmp(command, "render") == 0)
+        return cmd_render(argc - 1, argv + 1);
+    if (strcmp(command, "info") == 0)
+        return cmd_info(argc - 1, argv + 1);
+    if (strcmp(command, "version") == 0 || strcmp(command, "--version") == 0) {
+        printf("itbaa %s\n", itbaa_version());
+        return 0;
+    }
+    if (strcmp(command, "help") == 0 || strcmp(command, "--help") == 0 || strcmp(command, "-h") == 0) {
+        print_usage();
+        return 0;
+    }
+
+    fprintf(stderr, "error: unknown command '%s'\n\n", command);
+    print_usage();
+    return 1;
+}
