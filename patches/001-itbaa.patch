+
+namespace Itbaa {
+
+// Plays a recorded DisplayList onto an SkPDF page canvas for vector PDF output. Mirrors
+// DisplayListPlayerSkia but draws to its own SkCanvas, not a Gfx::PaintingSurface. Gradients
+// (emitted by SkPDF as native shadings), shadows, and nested display lists are fully painted;
+// compositor/video commands and SVG pattern fills have no PDF meaning and are no-ops.
+class DisplayListPlayerPDF final : public Web::Painting::DisplayListPlayer {
+public:
+    explicit DisplayListPlayerPDF(SkCanvas& canvas)
+        : m_canvas(canvas)
+    {
+    }
+    virtual ~DisplayListPlayerPDF() override = default;
+
+    virtual void flush(Gfx::PaintingSurface&) override { }
+
+private:
+    SkCanvas& canvas() { return m_canvas; }
+    Gfx::Path path_from_data(Web::Painting::DisplayListDataSpan) const;
+
+    virtual void draw_glyph_run(Web::Painting::DrawGlyphRun const&) override;
+    virtual void fill_rect(Web::Painting::FillRect const&) override;
+    virtual void draw_scaled_decoded_image_frame(Web::Painting::DrawScaledDecodedImageFrame const&) override;
+    virtual void draw_repeated_decoded_image_frame(Web::Painting::DrawRepeatedDecodedImageFrame const&) override;
+    virtual void draw_compositor_surface(Web::Painting::DrawCompositorSurface const&) override { }
+    virtual void draw_video_frame(Web::Painting::DrawVideoFrame const&) override { }
+    virtual void save(Web::Painting::Save const&) override;
+    virtual void save_layer(Web::Painting::SaveLayer const&) override;
+    virtual void restore(Web::Painting::Restore const&) override;
+    virtual void translate(Web::Painting::Translate const&) override;
+    virtual void add_clip_rect(Web::Painting::AddClipRect const&) override;
+    virtual void paint_linear_gradient(Web::Painting::PaintLinearGradient const&) override;
+    virtual void paint_radial_gradient(Web::Painting::PaintRadialGradient const&) override;
+    virtual void paint_conic_gradient(Web::Painting::PaintConicGradient const&) override;
+    virtual void paint_outer_box_shadow(Web::Painting::PaintOuterBoxShadow const&) override;
+    virtual void paint_inner_box_shadow(Web::Painting::PaintInnerBoxShadow const&) override;
+    virtual void paint_text_shadow(Web::Painting::PaintTextShadow const&) override;
+    virtual void fill_rect_with_rounded_corners(Web::Painting::FillRectWithRoundedCorners const&) override;
+    virtual void fill_path(Web::Painting::FillPath const&) override;
+    virtual void stroke_path(Web::Painting::StrokePath const&) override;
+    virtual void draw_ellipse(Web::Painting::DrawEllipse const&) override;
+    virtual void fill_ellipse(Web::Painting::FillEllipse const&) override;
+    virtual void draw_line(Web::Painting::DrawLine const&) override;
+    virtual void apply_backdrop_filter(Web::Painting::ApplyBackdropFilter const&) override { }
+    virtual void draw_rect(Web::Painting::DrawRect const&) override;
+    virtual void add_rounded_rect_clip(Web::Painting::AddRoundedRectClip const&) override;
+    virtual void paint_nested_display_list(Web::Painting::PaintNestedDisplayList const&) override;
+    virtual void compositor_scroll_node(Web::Painting::CompositorScrollNode const&) override { }
+    virtual void compositor_sticky_area(Web::Painting::CompositorStickyArea const&) override { }
+    virtual void compositor_wheel_hit_test_target(Web::Painting::CompositorWheelHitTestTarget const&) override { }
+    virtual void compositor_wheel_hit_test_target_with_corner_radii(Web::Painting::CompositorWheelHitTestTargetWithCornerRadii const&) override { }
+    virtual void compositor_main_thread_wheel_event_region(Web::Painting::CompositorMainThreadWheelEventRegion const&) override { }
+    virtual void compositor_viewport_scrollbar(Web::Painting::CompositorViewportScrollbar const&) override { }
+    virtual void compositor_blocking_wheel_event_region(Web::Painting::CompositorBlockingWheelEventRegion const&) override { }
+    virtual void paint_scrollbar(Web::Painting::PaintScrollBar const&) override { }
+    virtual void apply_effects(Web::Painting::ApplyEffects const&, Gfx::Filter const*) override;
+    virtual void apply_transform(Gfx::FloatPoint origin, Gfx::FloatMatrix4x4 const&) override;
+    virtual void add_clip_path(Gfx::Path const&) override;
+    virtual bool would_be_fully_clipped_by_painter(Gfx::IntRect) const override { return false; }
+
+    SkCanvas& m_canvas;
