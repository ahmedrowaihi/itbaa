+};
+
+}
diff --git a/Utilities/Itbaa/lib/ImageWriter.cpp b/Utilities/Itbaa/lib/ImageWriter.cpp
new file mode 100644
index 00000000000..c4dff345fbd
--- /dev/null
+++ b/Utilities/Itbaa/lib/ImageWriter.cpp
@@ -0,0 +1,96 @@
+/*
+ * Itbaa (اطبع) - HTML to PDF Conversion Library
+ * Copyright (c) 2025, sudorw <ahmedrowaihi@sudorw.com>
+ * SPDX-License-Identifier: BSD-2-Clause
+ */
+
+#include "ImageWriter.h"
+#include <AK/MemoryStream.h>
+#include <AK/StdLibExtras.h>
+#include <LibCore/File.h>
+#include <string.h>
+#include <LibGfx/Bitmap.h>
+#include <LibGfx/ImageFormats/JPEGWriter.h>
+#include <LibGfx/ImageFormats/PNGWriter.h>
+
+#include <core/SkCanvas.h>
+#include <core/SkColorType.h>
+#include <core/SkImageInfo.h>
+#include <core/SkPicture.h>
+#include <core/SkPixmap.h>
+#include <core/SkSurface.h>
+
+namespace Itbaa {
+
+sk_sp<SkImage> rasterize_page(RenderedPage const& page, float scale)
+{
+    if (scale <= 0.0f)
+        scale = 1.0f;
+
+    int width = AK::max(1, static_cast<int>(page.width * scale));
+    int height = AK::max(1, static_cast<int>(page.height * scale));
+
+    auto info = SkImageInfo::MakeN32Premul(width, height);
+    auto surface = SkSurfaces::Raster(info);
+    if (!surface)
+        return nullptr;
+
+    auto* canvas = surface->getCanvas();
+    canvas->clear(SK_ColorWHITE);
+    canvas->scale(scale, scale);
+    if (page.picture)
+        canvas->drawPicture(page.picture);
+
+    return surface->makeImageSnapshot();
+}
+
+// The bundled Skia is built without libpng/libjpeg encoders, so pixels are copied into a
+// Gfx::Bitmap and encoded with Ladybird's own writers.
+static ErrorOr<NonnullRefPtr<Gfx::Bitmap>> page_to_bitmap(RenderedPage const& page, float scale)
+{
+    auto image = rasterize_page(page, scale);
+    if (!image)
+        return Error::from_string_literal("Failed to rasterize page");
+
+    SkPixmap pixmap;
+    if (!image->peekPixels(&pixmap)) {
+        auto raster = image->makeRasterImage();
+        if (!raster || !raster->peekPixels(&pixmap))
+            return Error::from_string_literal("Failed to read rasterized pixels");
+    }
+
+    auto format = pixmap.colorType() == kRGBA_8888_SkColorType ? Gfx::BitmapFormat::RGBA8888 : Gfx::BitmapFormat::BGRA8888;
+    auto bitmap = TRY(Gfx::Bitmap::create(format, Gfx::AlphaType::Premultiplied, { pixmap.width(), pixmap.height() }));
+
+    auto const* source = static_cast<u8 const*>(pixmap.addr());
+    size_t row_bytes = static_cast<size_t>(pixmap.width()) * 4;
+    for (int y = 0; y < pixmap.height(); ++y)
+        memcpy(bitmap->scanline_u8(y), source + static_cast<size_t>(y) * pixmap.rowBytes(), row_bytes);
+
+    return bitmap;
+}
+
+ErrorOr<ByteBuffer> encode_image(RenderedPage const& page, ImageFormat format, float scale)
+{
+    auto bitmap = TRY(page_to_bitmap(page, scale));
+
+    if (format == ImageFormat::PNG)
+        return Gfx::PNGWriter::encode(*bitmap);
+
+    AllocatingMemoryStream stream;
+    Gfx::JPEGWriter::Options options;
+    options.quality = 90;
+    TRY(Gfx::JPEGWriter::encode(stream, *bitmap, options));
+    return stream.read_until_eof();
+}
+
+ErrorOr<void> write_image_to_file(RenderedPage const& page, StringView path, ImageFormat format, float scale)
+{
+    auto bytes = TRY(encode_image(page, format, scale));
+
+    auto file = TRY(Core::File::open(path, Core::File::OpenMode::Write | Core::File::OpenMode::Truncate));
+    TRY(file->write_until_depleted(bytes));
+    return {};
+}
+
+} // namespace Itbaa
